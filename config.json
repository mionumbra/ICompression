{
  "$schema": "./extgen.schema.json",
  "root": "./",
  "input": "./api.gmidl",
  "profile": "Full",
  "gamemaker": {
    "wrappers": {
      "enabled": true,
      "outputFile": "./project/scripts/ICompression_API/ICompression_API.gml"
    },
    "extension": {
      "enabled": true,
      "outputFile": "./project/extensions/ICompression/ICompression.yy",
      "mode": "patch",
      "extensionName": "ICompression",
      "extensionFileName": "ICompression.ext",
      "patchFrameworks": true
    },
    "runtime": {
      "enabled": true,
      "outputFile": "./project/scripts/GMExtCore/GMExtCore.gml"
    },
    "injectors": {
      "enabled": true,
      "outputFolder": "./project/extensions/ICompression/injectors"
    }
  },
  "targets": {
    "windows": {
      "enabled": true,
      "outputFolder": "./project/extensions/ICompression"
    }
  },
  "extras": {
    "docs": {
      "enabled": true,
      "outputFile": "./docs/documentation.json",
      "overwrite": true
    }
  },
  "build": {
    "emitCmake": true,
    "cmake": {
      "cppStandard": 20,
      "cppExtensions": false,
      "strictWarnings": true,
      "useThirdParty": true,
      "emitPresets": true
    }
  }
}
